{
  "rules": {
    "users": {
      "$user_id": {
        ".read":  "$user_id === auth.uid",
        ".write": "$user_id === auth.uid"
      },
	  ".indexOn": ["uid", "isAnonymous"]
    },
    "reports": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },
	"daily": {
	  "head": {
        ".read":  "auth != null",
	  },
	  "head_submit": {
		".read": "auth != null",
		".write": "auth != null",
		".indexOn": ["score"]
	  },
	  "reports": {
	    ".read":  "auth != null"
	  }
    },
	"pvp": {
	  "queue": {
	    ".read": "auth != null",
	    ".indexOn": ["ts"],
	    "$uid": {
	      ".write": "auth != null && auth.uid === $uid",
	      "matchId": {
	        ".write": "auth != null && data.val() === null && newData.val() !== null"
	      }
	    }
	  },
	  "matches": {
	    ".indexOn": ["meta/createdAt"],
	    "$matchId": {
	      ".read": "auth != null",
	      "meta":    { ".write": "auth != null && !data.exists()" },
	      "players": {
	        "$uid": { ".write": "auth != null && auth.uid === $uid" }
	      },
	      "result":  { ".write": "auth != null && !data.exists()" }
	    }
      }
    }
  }
}