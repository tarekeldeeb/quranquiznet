# Copy to `.env` and fill in your own values.
# Firebase: Console → Project Settings → Your apps → Web app → Config.
# NOTE: EXPO_PUBLIC_* vars are inlined into the client bundle and are therefore
# public. The Firebase web "apiKey" is a project identifier, not a secret —
# protect data with Firebase Security Rules / App Check, not by hiding the key.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
EXPO_PUBLIC_IPINFO_TOKEN=

# Native (iOS/Android) social sign-in via expo-auth-session. Not used on web
# (web uses the Firebase popup flow).
#
# GOOGLE: no env vars needed normally. Drop the standard Firebase config files
# into the project root (www/) and app.config.js reads the client IDs from them:
#   - GoogleService-Info.plist  → iOS client ID (Firebase Console → iOS app)
#   - google-services.json      → Android + Web client IDs (Firebase → Android app)
# The vars below are an OPTIONAL override if you'd rather not commit those files.
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Facebook: developers.facebook.com → your app → Settings → Basic → App ID.
# Native login redirects to fb<APP_ID>://authorize — Facebook accepts this
# automatically once the platforms are configured in the dashboard; do NOT try
# to whitelist a custom scheme in "Valid OAuth Redirect URIs" (https only).
# Required dashboard setup (Settings → Basic → Add Platform):
#   - iOS: Bundle ID `net.quranquiz.app`
#   - Android: package `net.quranquiz.app` + your debug/release key hashes
#   - Facebook Login → Settings: enable "Client OAuth Login"
# Changing this value? Also update the fb<APP_ID> scheme in the prebuilt
# projects (ios/.../Info.plist CFBundleURLSchemes, android AndroidManifest.xml)
# or re-run `npx expo prebuild`.
EXPO_PUBLIC_FACEBOOK_APP_ID=
