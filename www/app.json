{
  "expo": {
    "name": "اختبار القرآن",
    "slug": "quranquiznet",
    "version": "2.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "quranquiz",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d2d4e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "net.quranquiz"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#0d2d4e"
      },
      "package": "net.quranquiz",
      "versionCode": 11
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Amiri-Regular.woff2",
            "./assets/fonts/UthmanTN_v2-0.woff2",
            "./assets/fonts/PlexArabic-Regular.woff2",
            "./assets/fonts/PlexArabic-SemiBold.woff2",
            "./assets/fonts/PlexArabic-Bold.woff2"
          ]
        }
      ],
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
