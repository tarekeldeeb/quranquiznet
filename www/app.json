{
  "expo": {
    "name": "اختبار القرآن",
    "slug": "quranquiznet",
    "version": "2.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "quranquiz",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a5276"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "net.quranquiz.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#1a5276"
      },
      "package": "net.quranquiz.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Amiri-Regular.woff2",
            "./assets/fonts/AmiriQuranColored.woff2"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
