{
  "expo": {
    "name": "quran-quiz-شبكة-اختبار-القران",
    "slug": "quranquiznet",
    "version": "2.2.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "quranquiz",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "net.quranquiz",
      "buildNumber": "7",
      "appleTeamId": "FNSP52WBLF",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0d2d4e"
      },
      "package": "net.quranquiz",
      "versionCode": 14
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "newArchEnabled": false,
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-localization",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Amiri-Regular.woff2",
            "./assets/fonts/UthmanTN_v2-0.woff2",
            "./assets/fonts/PlexArabic-Regular.woff2",
            "./assets/fonts/PlexArabic-SemiBold.woff2",
            "./assets/fonts/PlexArabic-Bold.woff2"
          ]
        }
      ],
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "resizeMode": "cover",
          "backgroundColor": "#0d2d4e"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "ndkVersion": "28.2.13676358"
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "googleAuth": {
        "iosClientId": "635224907527-h6m6o8kqoud1bcroammqlf97ip6t41lt.apps.googleusercontent.com",
        "androidClientId": "635224907527-bqg6h4e8cpel7l9q14n2b084f71hch24.apps.googleusercontent.com",
        "webClientId": "635224907527-bdic77p58a8tjkeuj96csup7tnoe870s.apps.googleusercontent.com"
      },
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "5c3fe7d8-80ae-44cf-81d6-b65b253ae52f"
      }
    },
    "owner": "tarekeldeeb"
  }
}
