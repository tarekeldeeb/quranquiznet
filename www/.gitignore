

# Build outputs / caches (generated by `npx expo export` and the dev server).
# Hosting is deployed from a fresh local build, so these never need to be tracked.
# Anchored to root: an unanchored `dist/` also matches public/quran-madina/dist/,
# which holds committed source assets (synced from the pinned quran-madina-html
# npm package by scripts/sync-madina-assets.mjs), not build output.
/dist/
web-build/
.expo/

# Native projects — regenerated on demand by `npx expo prebuild`.
# Managed (CNG) workflow, so the android/ and ios/ dirs are not tracked.
/android
/ios

# Local environment files (Firebase / ipinfo config). Keep .env.example tracked.
.env
.env.local
.env*.local
!.env.example
