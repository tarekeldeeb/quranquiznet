[70,27,571,[{"l":12,"t":" وَقَالَ نُوحٌ رَّبِّ لَا تَذَرْ عَلَى ٱلْأَرْضِ مِنَ ٱلْكَـٰفِرِينَ","s":0.87},{"l":13,"t":"دَيَّارًا ﴿٢٦﴾","s":0.952}]],[70,28,571,[{"l":13,"t":" إِنَّكَ إِن تَذَرْهُمْ يُضِلُّوا۟ عِبَادَكَ وَلَا يَلِدُوٓا۟ إِلَّا فَاجِرًا","s":0.952},{"l":14,"t":"كَفَّـارًا ﴿٢٧﴾","s":0.956}]],[70,29,571,[{"l":14,"t":" رَّبِّ ٱغْفِـرْ لِـى وَلِوَٰلِـدَىَّ وَلِمَـن دَخَـلَ بَيْتِـىَ","s":0.956},{"l":15,"t":"مُؤْمِنًا وَلِلْمُؤْمِنِينَ وَٱلْمُؤْمِنَـٰتِ وَلَا تَزِدِ ٱلظَّـٰلِمِينَ إِلَّا تَبَارًۢا ﴿٢٨﴾","s":0.903}]],[71,0,572,[{"l":1,"t":"سورة الجن","s":-1}]],[71,1,572,[{"l":2,"t":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ","s":-1}]],[71,2,572,[{"l":3,"t":"قُلْ أُوحِىَ إِلَىَّ أَنَّهُ ٱسْتَمَعَ نَفَرٌ مِّنَ ٱلْجِنِّ فَقَالُوٓا۟ إِنَّا سَمِعْنَا قُرْءَانًا","s":0.967},{"l":4,"t":"عَجَبًا ﴿١﴾","s":0.86}]],[71,3,572,[{"l":4,"t":" يَهْدِىٓ إِلَى ٱلرُّشْدِ فَـَٔامَنَّا بِهِۦۖ وَلَن نُّشْرِكَ بِرَبِّنَآ أَحَدًا ﴿٢﴾","s":0.86}]],[71,4,572,[{"l":5,"t":"وَأَنَّهُۥ تَعَـٰلَىٰ جَدُّ رَبِّنَا مَا ٱتَّخَذَ صَـٰحِبَةً وَلَا وَلَدًا ﴿٣﴾","s":0.93}]],[71,5,572,[{"l":5,"t":" وَأَنَّهُۥ كَانَ","s":0.93},{"l":6,"t":"يَقُولُ سَفِيهُنَا عَلَى ٱللَّهِ شَطَطًا ﴿٤﴾","s":0.913}]],[71,6,572,[{"l":6,"t":" وَأَنَّا ظَنَنَّآ أَن لَّن تَقُولَ ٱلْإِنسُ","s":0.913},{"l":7,"t":"وَٱلْجِنُّ عَلَى ٱللَّهِ كَذِبًا ﴿٥﴾","s":0.839}]],[71,7,572,[{"l":7,"t":" وَأَنَّهُۥ كَانَ رِجَالٌ مِّنَ ٱلْإِنسِ يَعُوذُونَ بِرِجَالٍ","s":0.839},{"l":8,"t":"مِّنَ ٱلْجِنِّ فَزَادُوهُمْ رَهَقًا ﴿٦﴾","s":0.885}]],[71,8,572,[{"l":8,"t":" وَأَنَّهُمْ ظَنُّوا۟ كَمَا ظَنَنتُمْ أَن لَّن يَبْعَثَ","s":0.885},{"l":9,"t":"ٱللَّـهُ أَحَدًا ﴿٧﴾","s":1.003}]],[71,9,572,[{"l":9,"t":" وَأَنَّا لَمَسْنَا ٱلسَّمَآءَ فَوَجَدْنَـٰهَا مُلِئَتْ حَرَسًا","s":1.003},{"l":10,"t":"شَدِيدًا وَشُهُبًا ﴿٨﴾","s":0.988}]],[71,10,572,[{"l":10,"t":" وَأَنَّا كُنَّا نَقْعُدُ مِنْهَا مَقَـٰعِدَ لِلسَّمْعِۖ فَمَن","s":0.988},{"l":11,"t":"يَسْتَمِعِ ٱلْـَٔانَ يَجِدْ لَهُۥ شِهَابًا رَّصَدًا ﴿٩﴾","s":0.931}]],[71,11,572,[{"l":11,"t":" وَأَنَّا لَا نَ