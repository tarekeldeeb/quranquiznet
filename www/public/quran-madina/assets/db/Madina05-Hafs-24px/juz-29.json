:8,"t":" قَالُوا۟ يَـٰوَيْلَنَآ إِنَّا كُنَّا طَـٰغِينَ ﴿٣١﴾","s":0.762}]],[67,33,565,[{"l":8,"t":" عَسَىٰ","s":0.762},{"l":9,"t":"رَبُّنَآ أَن يُبْدِلَنَا خَيْرًا مِّنْهَآ إِنَّآ إِلَىٰ رَبِّنَا رَٰغِبُونَ ﴿٣٢﴾","s":0.76}]],[67,34,565,[{"l":9,"t":" كَذَٰلِكَ ٱلْعَذَابُۖ وَلَعَذَابُ","s":0.76},{"l":10,"t":"ٱلْـَٔاخِرَةِ أَكْبَرُۚ لَوْ كَانُوا۟ يَعْلَمُونَ ﴿٣٣﴾","s":0.78}]],[67,35,565,[{"l":10,"t":" إِنَّ لِلْمُتَّقِينَ عِندَ رَبِّهِمْ جَنَّـٰتِ ٱلنَّعِيمِ","s":0.78},{"l":11,"t":"﴿٣٤﴾","s":0.719}]],[67,36,565,[{"l":11,"t":" أَفَنَجْعَلُ ٱلْمُسْلِمِينَ كَٱلْمُجْرِمِينَ ﴿٣٥﴾","s":0.719}]],[67,37,565,[{"l":11,"t":" مَا لَكُمْ كَيْفَ تَحْكُمُونَ ﴿٣٦﴾","s":0.719}]],[67,38,565,[{"l":11,"t":" أَمْ","s":0.719},{"l":12,"t":"لَكُمْ كِتَـٰبٌ فِيهِ تَدْرُسُونَ ﴿٣٧﴾","s":0.703}]],[67,39,565,[{"l":12,"t":" إِنَّ لَكُمْ فِيهِ لَمَا تَخَيَّرُونَ ﴿٣٨﴾","s":0.703}]],[67,40,565,[{"l":12,"t":" أَمْ لَكُمْ أَيْمَـٰنٌ","s":0.703},{"l":13,"t":"عَلَيْنَا بَـٰلِغَةٌ إِلَىٰ يَوْمِ ٱلْقِيَـٰمَةِۙ إِنَّ لَكُمْ لَمَا تَحْكُمُونَ ﴿٣٩﴾","s":0.838}]],[67,41,565,[{"l":13,"t":" سَلْهُمْ أَيُّهُم","s":0.838},{"l":14,"t":"بِذَٰلِكَ زَعِيمٌ ﴿٤٠﴾","s":0.767}]],[67,42,565,[{"l":14,"t":" أَمْ لَهُمْ شُرَكَآءُ فَلْيَأْتُوا۟ بِشُرَكَآئِهِمْ إِن كَانُوا۟ صَـٰدِقِينَ ﴿٤١﴾","s":0.767}]],[67,43,565,[{"l":15,"t":"يَوْمَ يُكْشَفُ عَن سَاقٍ وَيُدْعَوْنَ إِلَى ٱلسُّجُودِ فَلَا يَسْتَطِيعُونَ ﴿٤٢﴾","s":0.86}]],[67,44,566,[{"l":1,"t":"خَـٰشِعَةً أَبْصَـٰرُهُمْ تَرْهَقُهُمْ ذِلَّةٌۖ وَقَدْ كَانُوا۟ يُدْعَوْنَ إِلَى ٱلسُّجُودِ وَهُمْ سَـٰلِمُونَ","s":0.782},{"l":2,"t":"﴿٤٣﴾","s":0.867}]],[67,45,566,[{"l":2,"t":" فَذَرْنِى وَمَن يُكَذِّبُ بِهَـٰذَا ٱلْحَدِيثِۖ سَنَسْتَدْرِجُهُم مِّنْ حَيْثُ","s":0.867},{"l":3,"t":"لَا يَعْلَمُونَ ﴿٤٤﴾","s":0.807}]],[67,46,566,[{"l":3,"t":" وَأُمْلِى لَهُمْۚ إِنَّ كَيْدِى مَتِينٌ ﴿٤٥﴾","s":0.807}]],[67,47,566,[{"l":3,"t":" أَمْ تَسْـَٔلُهُمْ أَجْرًا فَهُم","s":0.807},{"l":4,"t":"مِّن مَّغْرَمٍ مُّثْقَلُونَ ﴿٤٦﴾","s":0.804}]],[67,48,566,[{"l":4,"t":" أَمْ عِندَهُمُ ٱلْغَيْبُ فَهُمْ يَكْتُبُونَ ﴿٤٧﴾","s":0.804}]],[67,49,566,[{"l":4,"t":" فَٱصْبِرْ","s":0.804},{"l":5,"t":"لِحُكْمِ رَبِّكَ وَلَا تَكُن كَصَاحِبِ ٱلْحُوتِ إِذْ نَادَىٰ وَهُوَ مَكْظُومٌ ﴿٤٨﴾","s":0.773}]],[67,50,566,[{"l":5,"t":" لَّوْلَآ","s":0.773},{"l":6,"t":"أَن تَدَٰرَكَهُۥ نِعْمَةٌ مِّن رَّبِّهِۦ لَنُبِذَ بِٱلْعَرَآءِ وَهُوَ مَذْمُومٌ ﴿٤٩﴾","s":0.809}]],[67,51,566,[{"l":6,"t":" فَٱجْتَبَـٰهُ رَبُّهُۥ","s":0.809},{"l":7,"t":"فَجَعَلَهُۥ مِنَ ٱلصَّـٰلِحِينَ ﴿٥٠﴾","s":0.769}]],[67,52,566,[{"l":7,"t":" وَإِن يَكَادُ ٱلَّذِينَ كَفَرُوا۟ لَيُزْلِقُونَكَ بِأَبْصَـٰرِهِمْ","s":0.769},{"l":8,"t":"لَمَّا سَمِعُوا۟ ٱلذِّكْرَ وَيَقُولُونَ إِنَّهُۥ لَمَجْنُونٌ ﴿٥١﴾","s":0.732}]],[67,53,566,[{"l":8,"t":" وَمَا هُوَ إِلَّا ذِكْرٌ لِّلْعَـٰلَمِينَ ﴿٥٢﴾","s":0.732}]],[68,0,566,[{"l":9,"t":"سورة الحاقة","s":-1}]],[68,1,566,[{"l":10,"t":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ","s":-1}]],[68,2,566,[{"l":11,"t":"ٱلْحَآقَّةُ ﴿١﴾","s":0.854}]],[68,3,566,[{"l":11,"t":" مَا ٱلْحَآقَّةُ ﴿٢﴾","s":0.854}]],[68,4,566,[{"l":11,"t":" وَمَآ أَدْرَىٰكَ مَا ٱلْحَآقَّةُ ﴿٣﴾","s":0.854}]],[68,5,566,[{"l":11,"t":" كَذَّبَتْ ثَمُودُ","s":0.854},{"l":12,"t":"وَعَادٌۢ بِٱلْقَارِعَةِ ﴿٤﴾","s":0.978}]],[68,6,566,[{"l":12,"t":" فَأَمَّا ثَمُودُ فَأُهْلِكُوا۟ بِٱلطَّاغِيَةِ ﴿٥﴾","s":0.978}]],[68,7,566,[{"l":12,"t":" وَأَمَّا","s":0.978},{"l":13,"t":"عَـادٌ فَأُهْلِكُـوا۟ بِرِيـحٍ صَرْصَرٍ عَاتِيَـةٍ ﴿٦﴾","s":0.977}]],[68,8,566,[{"l":13,"t":" سَخَّرَهَـا عَلَيْهِمْ","s":0.977},{"l":14,"t":"سَبْـعَ لَيَالٍ وَثَمَـٰنِيَةَ أَيَّـامٍ حُسُومًا فَتَرَى ٱلْقَـوْمَ فِيهَا صَرْعَىٰ","s":0.985},{"l":15,"t":"كَأَنَّهُمْ أَعْجَازُ نَخْلٍ خَاوِيَةٍ ﴿٧﴾","s":0.937}]],[68,9,566,[{"l":15,"t":" فَهَلْ تَرَىٰ لَهُم مِّنۢ بَاقِيَةٍ ﴿٨﴾","s":0.937}]],[68,10,567,[{"l":1,"t":"وَجَآءَ فِرْعَوْنُ وَمَن قَبْلَهُۥ وَٱلْمُؤْتَفِكَـٰتُ بِٱلْخَاطِئَةِ ﴿٩﴾","s":0.858}]],[68,11,567,[{"l":1,"t":" فَعَصَوْا۟ رَسُولَ","s":0.858},{"l":2,"t":"رَبِّهِمْ فَأَخَذَهُمْ أَخْذَةً رَّابِيَةً ﴿١٠﴾","s":0.813}]],[68,12,567,[{"l":2,"t":" إِنَّا لَمَّا طَغَا ٱل