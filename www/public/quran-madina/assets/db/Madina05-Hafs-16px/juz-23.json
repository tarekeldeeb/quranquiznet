{"j":22,"d":[[35,29,442,[{"l":1,"t":"۞ وَمَآ أَنزَلْنَا عَلَىٰ قَوْمِهِۦ مِنۢ بَعْدِهِۦ مِن جُندٍ مِّنَ ٱلسَّمَآءِ وَمَا","s":0.958},{"l":2,"t":"كُنَّا مُنزِلِينَ ﴿٢٨﴾","s":0.894}]],[35,30,442,[{"l":2,"t":" إِن كَانَتْ إِلَّا صَيْحَةً وَٰحِدَةً فَإِذَا هُمْ خَـٰمِدُونَ","s":0.894},{"l":3,"t":"﴿٢٩﴾","s":0.965}]],[35,31,442,[{"l":3,"t":" يَـٰحَسْرَةً عَلَى ٱلْعِبَادِۚ مَا يَأْتِيهِم مِّن رَّسُولٍ إِلَّا كَانُوا۟ بِهِۦ","s":0.965},{"l":4,"t":"يَسْتَهْزِءُونَ ﴿٣٠﴾","s":0.988}]],[35,32,442,[{"l":4,"t":" أَلَمْ يَرَوْا۟ كَمْ أَهْلَكْنَا قَبْلَهُم مِّنَ ٱلْقُرُونِ","s":0.988},{"l":5,"t":"أَنَّهُمْ إِلَيْهِمْ لَا يَرْجِعُونَ ﴿٣١﴾","s":0.924}]],[35,33,442,[{"l":5,"t":" وَإِن كُلٌّ لَّمَّا جَمِيعٌ لَّدَيْنَا مُحْضَرُونَ","s":0.924},{"l":6,"t":"﴿٣٢﴾","s":0.964}]],[35,34,442,[{"l":6,"t":" وَءَايَةٌ لَّهُمُ ٱلْأَرْضُ ٱلْمَيْتَةُ أَحْيَيْنَـٰهَا وَأَخْرَجْنَا مِنْهَا حَبًّا","s":0.964},{"l":7,"t":"فَمِنْـهُ يَأْكُلُـونَ ﴿٣٣﴾","s":0.99}]],[35,35,442,[{"l":7,"t":" وَجَعَلْنَـا فِيهَا جَـنَّـٰتٍ مِّـن نَّخِيلٍ","s":0.99},{"l":8,"t":"وَأَعْنَـٰبٍ وَفَجَّرْنَا فِيهَا مِنَ ٱلْعُيُونِ ﴿٣٤﴾","s":0.945}]],[35,36,442,[{"l":8,"t":" لِيَأْكُلُوا۟ مِن ثَمَرِهِۦ","s":0.945},{"l":9,"t":"وَمَـا عَمِلَتْهُ أَيْدِيهِـمْۖ أَفَلَا يَشْكُـرُونَ ﴿٣٥﴾","s":0.987}]],[35,37,442,[{"l":9,"t":" سُبْحَـٰنَ ٱلَّذِى","s":0.987},{"l":10,"t":"خَلَــقَ ٱلْأَزْوَٰجَ كُلَّهَـا مِمَّـا تُنۢبِـتُ ٱلْأَرْضُ وَمِـنْ أَنفُسِهِـمْ","s":0.987},{"l":11,"t":"وَمِمَّـا لَا يَعْلَمُونَ ﴿٣٦﴾","s":0.983}]],[35,38,442,[{"l":11,"t":" وَءَايَةٌ لَّهُمُ ٱلَّيْـلُ نَسْلَخُ مِنْهُ ٱلنَّهَارَ","s":0.983},{"l":12,"t":"فَـإِذَا هُـم مُّظْلِمُـونَ ﴿٣٧﴾","s":0.984}]],[35,39,442,[{"l":12,"t":" وَٱلشَّمْسُ تَجْـرِى لِمُسْتَقَـرٍّ لَّهَاۚ","s":0.984},{"l":13,"t":"ذَٰلِكَ تَقْدِيرُ ٱلْعَزِيزِ ٱلْعَلِيمِ ﴿٣٨﴾","s":0.939}]],[35,40,442,[{"l":13,"t":" وَٱلْقَمَرَ قَدَّرْنَـٰهُ مَنَازِلَ حَتَّىٰ","s":0.939},{"l":14,"t":"عَادَ كَٱلْعُرْجُونِ ٱلْقَدِيمِ ﴿٣٩﴾","s":0.934}]],[35,41,442,[{"l":14,"t":" لَا ٱلشَّمْسُ يَنۢبَغِى لَهَآ أَن تُدْرِكَ","s":0.934},{"l":15,"t":"ٱلْقَمَـرَ وَلَا ٱلَّيْلُ سَابِقُ ٱلنَّهَارِۚ وَكُلٌّ فِى فَلَكٍ يَسْبَحُونَ ﴿٤٠﴾","s":0.986}]],[35,42,443,[{"l":1,"t":"وَءَايَةٌ لَّهُمْ أَنَّا حَمَلْنَا ذُرِّيَّتَهُمْ فِى ٱلْفُلْكِ ٱلْمَشْحُونِ ﴿٤١﴾","s":0.923}]],[35,43,443,[{"l":1,"t":" وَخَلَقْنَا","s":0.923},{"l":2,"t":"لَهُم مِّن مِّثْلِهِۦ مَا يَرْكَبُونَ ﴿٤٢﴾","s":0.895}]],[35,44,443,[{"l":2,"t":" وَإِن نَّشَأْ نُغْرِقْهُمْ فَلَا صَرِيخَ لَهُمْ","s":0.895},{"l":3,"t":"وَلَا هُمْ يُنقَذُونَ ﴿٤٣﴾","s":0.895}]],[35,45,443,[{"l":3,"t":" إِلَّا رَحْمَةً مِّنَّا وَمَتَـٰعًا إِلَىٰ حِينٍ ﴿٤٤﴾","s":0.895}]],[35,46,443,[{"l":3,"t":" وَإِذَا","s":0.895},{"l":4,"t":"قِيلَ لَهُمُ ٱتَّقُوا۟ مَا بَيْنَ أَيْدِيكُمْ وَمَا خَلْفَكُمْ لَعَلَّكُمْ تُرْحَمُونَ ﴿٤٥﴾","s":0.83}]],[35,47,443,[{"l":5,"t":"وَمَا تَأْتِيهِم مِّنْ ءَايَةٍ مِّنْ ءَايَـٰتِ رَبِّهِمْ إِلَّا كَانُوا۟ عَنْهَا مُعْرِضِينَ","s":0.952},{"l":6,"t":"﴿٤٦﴾","s":0.904}]],[35,48,443,[{"l":6,"t":" وَإِذَا قِيلَ لَهُمْ أَنفِقُوا۟ مِمَّا رَزَقَكُمُ ٱللَّهُ قَالَ ٱلَّذِينَ كَفَرُوا۟","s":0.904},{"l":7,"t":"لِلَّذِينَ ءَامَنُوٓا۟ أَنُطْعِمُ مَن لَّوْ يَشَآءُ ٱللَّهُ أَطْعَمَهُۥٓ إِنْ أَنتُمْ إِلَّا فِى","s":0.972},{"l":8,"t":"ضَلَـٰلٍ مُّبِينٍ ﴿٤٧﴾","s":0.893}]],[35,49,443,[{"l":8,"t":" وَيَقُولُونَ مَتَىٰ هَـٰذَا ٱلْوَعْدُ إِن كُنتُمْ صَـٰدِقِينَ","s":0.893},{"l":9,"t":"﴿٤٨﴾","s":0.956}]],[35,50,443,[{"l":9,"t":" مَا يَنظُرُونَ إِلَّا صَيْحَةً وَٰحِدَةً تَأْخُذُهُمْ وَهُمْ يَخِصِّمُونَ","s":0.956},{"l":10,"t":"﴿٤٩﴾","s":0.958}]],[35,51,443,[{"l":10,"t":" فَلَا يَسْتَطِيعُونَ تَوْصِيَةً وَلَآ إِلَىٰٓ أَهْلِهِمْ يَرْجِعُونَ ﴿٥٠﴾","s":0.958}]],[35,52,443,[{"l":11,"t":"وَنُفِـخَ فِى ٱلصُّورِ فَإِذَا هُم مِّـنَ ٱلْأَجْدَاثِ إِلَىٰ رَبِّهِمْ يَنسِلُونَ","s":0.994},{"l":12,"t":"﴿٥١﴾","s":0.916}]],[35,53,443,[{"l":12,"t":" قَالُوا۟ يَـٰوَيْلَنَا مَنۢ بَعَثَنَا مِن مَّرْقَدِنَاۜۗ هَـٰذَا مَا وَعَدَ ٱلرَّحْمَـٰنُ","s":0.916},{"l":13,"t":"وَصَـــدَقَ ٱلْمُرْسَلُـــونَ ﴿٥٢﴾","s":1.0}]],[35,54,443,[{"l":13,"t":" إِن كَانَـــتْ إِلَّا صَيْحَــةً","s":1.0},{"l":14,"t":"وَٰحِدَةً فَإِذَا هُمْ جَمِيعٌ لَّدَيْنَا مُحْضَرُونَ ﴿٥٣﴾","s":0.984}]],[35,55,443,[{"l":14,"t":" فَٱلْيَوْمَ لَا تُظْلَمُ","s":0.984},{"l":15,"t":"نَفْـسٌ شَـيْـًٔا وَلَا تُجْـزَوْنَ إِلَّا مَـا كُنتُـمْ تَعْمَلُـونَ ﴿٥٤﴾","s":0.997}]],[35,56,444,[{"l":1,"t":"إِنَّ أَصْحَـٰبَ ٱلْجَنَّةِ ٱلْيَوْمَ فِى شُغُلٍ فَـٰكِهُونَ ﴿٥٥﴾","s":0.91}]],[35,57,444,[{"l":1,"t":" هُمْ وَأَزْوَٰجُهُمْ","s":0.91},{"l":2,"t":"فِى ظِلَـٰلٍ عَلَى ٱلْأَرَآئِكِ مُتَّكِـُٔونَ ﴿٥٦﴾","s":0.948}]],[35,58,444,[{"l":2,"t":" لَهُمْ فِيهَا فَـٰكِهَةٌ وَلَهُم","s":0.948},{"l":3,"t":"مَّا يَدَّعُونَ ﴿٥٧﴾","s":0.871}]],[35,59,444,[{"l":3,"t":" سَلَـٰمٌ قَوْلًا مِّن رَّبٍّ رَّحِيمٍ ﴿٥٨﴾","s":0.871}]],[35,60,444,[{"l":3,"t":" وَٱمْتَـٰزُوا۟ ٱلْيَوْمَ","s":0.871},{"l":4,"t":"أَيُّهَا ٱلْمُجْرِمُونَ ﴿٥٩﴾","s":0.936}]],[35,61,444,[{"l":4,"t":" ۞ أَلَمْ أَعْهَدْ إِلَيْكُمْ يَـٰبَنِىٓ ءَادَمَ أَن لَّا","s":0.936},{"l":5,"t":"تَعْبُدُوا۟ ٱلشَّيْطَـٰنَۖ إِنَّهُۥ لَكُمْ عَدُوٌّ مُّبِينٌ ﴿٦٠﴾","s":0.96}]],[35,62,444,[{"l":5,"t":" وَأَنِ ٱعْبُدُونِىۚ","s":0.96},{"l":6,"t":"هَـٰذَا صِرَٰطٌ مُّسْتَقِيمٌ ﴿٦١﴾","s":0.961}]],[35,63,444,[{"l":6,"t":" وَلَقَدْ أَضَلَّ مِنكُمْ جِبِلًّا كَثِيرًاۖ","s":0.961},{"l":7,"t":"أَفَلَمْ تَكُونُوا۟ تَعْقِلُونَ ﴿٦٢﴾","s":0.924}]],[35,64,444,[{"l":7,"t":" هَـٰذِهِۦ جَهَنَّمُ ٱلَّتِى كُنتُمْ تُوعَدُونَ","s":0.924},{"l":8,"t":"﴿٦٣﴾","s":0.968}]],[35,65,444,[{"l":8,"t":" ٱصْلَوْهَا ٱلْيَوْمَ بِمَا كُنتُمْ تَكْفُرُونَ ﴿٦٤﴾","s":0.968}]],[35,66,444,[{"l":8,"t":" ٱلْيَوْمَ نَخْتِمُ","s":0.968},{"l":9,"t":"عَلَـىٰٓ أَفْوَٰهِهِـمْ وَتُكَلِّمُنَآ أَيْدِيهِـمْ وَتَشْهَـدُ أَرْجُلُهُم بِمَـا كَانُوا۟","s":0.962},{"l":10,"t":"يَكْسِبُونَ ﴿٦٥﴾","s":0.994}]],[35,67,444,[{"l":10,"t":" وَلَوْ نَشَآءُ لَطَمَسْنَا عَلَىٰٓ أَعْيُنِهِمْ فَٱسْتَبَقُوا۟","s":0.994},{"l":11,"t":"ٱلصِّـرَٰطَ فَأَنَّـىٰ يُبْصِـرُونَ ﴿٦٦﴾","s":0.975}]],[35,68,444,[{"l":11,"t":" وَلَـوْ نَشَـآءُ لَمَسَخْنَـٰهُـمْ","s":0.975},{"l":12,"t":"عَلَــىٰ مَكَانَتِهِــمْ فَمَــا ٱسْتَطَـٰعُــوا۟ مُضِيًّــا وَلَا يَرْجِعُـونَ","s":0.959},{"l":13,"t":"﴿٦٧﴾","s":0.996}]],[35,69,444,[{"l":13,"t":" وَمَن نُّعَمِّرْهُ نُنَكِّسْهُ فِى ٱلْخَلْقِۖ أَفَلَا يَعْقِلُونَ ﴿٦٨﴾","s":0.996}]],[35,70,444,[{"l":14,"t":"وَمَا عَلَّمْنَـٰهُ ٱلشِّعْرَ وَمَا يَنۢبَغِى لَهُۥٓۚ إِنْ هُوَ إِلَّا ذِكْرٌ وَقُرْءَانٌ مُّبِينٌ","s":0.926},{"l":15,"t":"﴿٦٩﴾","s":0.928}]],[35,71,444,[{"l":15,"t":" لِّيُنذِرَ مَن كَانَ حَيًّا وَيَحِقَّ ٱلْقَوْلُ عَلَى ٱلْكَـٰفِرِينَ ﴿٧٠﴾","s":0.928}]],[35,72,445,[{"l":1,"t":"أَوَلَـمْ يَرَوْا۟ أَنَّا خَلَقْنَا لَهُم مِّمَّا عَمِلَتْ أَيْدِينَآ أَنْعَـٰمًا فَهُمْ لَهَا","s":0.979},{"l":2,"t":"مَـٰلِكُونَ ﴿٧١﴾","s":0.852}]],[35,73,445,[{"l":2,"t":" وَذَلَّلْنَـٰهَا لَهُمْ فَمِنْهَا رَكُوبُهُمْ وَمِنْهَا يَأْكُلُونَ ﴿٧٢﴾","s":0.852}]],[35,74,445,[{"l":3,"t":"وَلَهُـمْ فِيهَا مَنَـٰفِعُ وَمَشَارِبُۖ أَفَلَا يَشْكُرُونَ ﴿٧٣﴾","s":0.986}]],[35,75,445,[{"l":3,"t":" وَٱتَّخَذُوا۟","s":0.986},{"l":4,"t":"مِـن دُونِ ٱللَّهِ ءَالِهَةً لَّعَلَّهُـمْ يُنصَرُونَ ﴿٧٤﴾","s":0.981}]],[35,76,445,[{"l":4,"t":" لَا يَسْتَطِيعُونَ","s":0.981},{"l":5,"t":"نَصْرَهُـمْ وَهُمْ لَهُمْ جُندٌ مُّحْضَرُونَ ﴿٧٥﴾","s":0.996}]],[35,77,445,[{"l":5,"t":" فَلَا يَحْزُنكَ قَوْلُهُمْۘ","s":0.996},{"l":6,"t":"إِنَّا نَعْلَمُ مَا يُسِرُّونَ وَمَا يُعْلِنُونَ ﴿٧٦﴾","s":0.985}]],[35,78,445,[{"l":6,"t":" أَوَلَمْ يَرَ ٱلْإِنسَـٰنُ أَنَّا","s":0.985},{"l":7,"t":"خَلَقْنَـٰهُ مِن نُّطْفَةٍ فَإِذَا هُوَ خَصِيمٌ مُّبِينٌ ﴿٧٧﴾","s":0.989}]],[35,79,445,[{"l":7,"t":" وَضَرَبَ لَنَا","s":0.989},{"l":8,"t":"مَثَلًا وَنَسِىَ خَلْقَهُۥۖ قَالَ مَن يُحْىِ ٱلْعِظَـٰمَ وَهِىَ رَمِيمٌ ﴿٧٨﴾","s":0.982}]],[35,80,445,[{"l":9,"t":"قُـلْ يُحْيِيهَا ٱلَّـذِىٓ أَنشَأَهَآ أَوَّلَ مَـرَّةٍۖ وَهُوَ بِكُـلِّ خَلْقٍ عَلِيمٌ","s":0.954},{"l":10,"t":"﴿٧٩﴾","s":0.979}]],[35,81,445,[{"l":10,"t":" ٱلَّذِى جَعَلَ لَكُم مِّنَ ٱلشَّجَرِ ٱلْأَخْضَرِ نَارًا فَإِذَآ أَنتُم","s":0.979},{"l":11,"t":"مِّنْهُ تُوقِدُونَ ﴿٨٠﴾","s":0.986}]],[35,82,445,[{"l":11,"t":" أَوَلَيْسَ ٱلَّذِى خَلَقَ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضَ","s":0.986},{"l":12,"t":"بِـقَـٰدِرٍ عَلَىٰٓ 