,"s":0.88}]],[37,33,455,[{"l":6,"t":" فَقَالَ إِنِّىٓ","s":0.88},{"l":7,"t":"أَحْبَبْتُ حُبَّ ٱلْخَيْرِ عَن ذِكْرِ رَبِّى حَتَّىٰ تَوَارَتْ بِٱلْحِجَابِ ﴿٣٢﴾","s":0.915}]],[37,34,455,[{"l":8,"t":"رُدُّوهَا عَلَىَّۖ فَطَفِقَ مَسْحًۢا بِٱلسُّوقِ وَٱلْأَعْنَاقِ ﴿٣٣﴾","s":0.951}]],[37,35,455,[{"l":8,"t":" وَلَقَدْ فَتَنَّا","s":0.951},{"l":9,"t":"سُلَيْمَـٰنَ وَأَلْقَيْنَا عَلَىٰ كُرْسِيِّهِۦ جَسَدًا ثُمَّ أَنَابَ ﴿٣٤﴾","s":0.86}]],[37,36,455,[{"l":9,"t":" قَالَ رَبِّ ٱغْفِرْ","s":0.86},{"l":10,"t":"لِى وَهَبْ لِى مُلْكًا لَّا يَنۢبَغِى لِأَحَدٍ مِّنۢ بَعْدِىٓۖ إِنَّكَ أَنتَ ٱلْوَهَّابُ ﴿٣٥﴾","s":0.841}]],[37,37,455,[{"l":11,"t":"فَسَخَّرْنَا لَهُ ٱلرِّيحَ تَجْرِى بِأَمْرِهِۦ رُخَآءً حَيْثُ أَصَابَ ﴿٣٦﴾","s":0.825}]],[37,38,455,[{"l":11,"t":" وَٱلشَّيَـٰطِينَ","s":0.825},{"l":12,"t":"كُلَّ بَنَّآءٍ وَغَوَّاصٍ ﴿٣٧﴾","s":0.854}]],[37,39,455,[{"l":12,"t":" وَءَاخَرِينَ مُقَرَّنِينَ فِى ٱلْأَصْفَادِ ﴿٣٨﴾","s":0.854}]],[37,40,455,[{"l":12,"t":" هَـٰذَا","s":0.854},{"l":13,"t":"عَطَآؤُنَا فَٱمْنُنْ أَوْ أَمْسِكْ بِغَيْرِ حِسَابٍ ﴿٣٩﴾","s":0.774}]],[37,41,455,[{"l":13,"t":" وَإِنَّ لَهُۥ عِندَنَا لَزُلْفَىٰ وَحُسْنَ","s":0.774},{"l":14,"t":"مَـَٔابٍ ﴿٤٠﴾","s":0.856}]],[37,42,455,[{"l":14,"t":" وَٱذْكُرْ عَبْدَنَآ أَيُّوبَ إِذْ نَادَىٰ رَبَّهُۥٓ أَنِّى مَسَّنِىَ ٱلشَّيْطَـٰنُ","s":0.856},{"l":15,"t":"بِنُصْبٍ وَعَذَابٍ ﴿٤١﴾","s":0.795}]],[37,43,455,[{"l":15,"t":" ٱرْكُضْ بِرِجْلِكَۖ هَـٰذَا مُغْتَسَلٌۢ بَارِدٌ وَشَرَابٌ ﴿٤٢﴾","s":0.795}]],[37,44,456,[{"l":1,"t":"وَوَهَبْنَا لَهُۥٓ أَهْلَهُۥ وَمِثْلَهُم مَّعَهُمْ رَحْمَةً مِّنَّا وَذِكْرَىٰ لِأُو۟لِى ٱلْأَلْبَـٰبِ","s":0.897},{"l":2,"t":"﴿٤٣﴾","s":0.866}]],[37,45,456,[{"l":2,"t":" وَخُذْ بِيَدِكَ ضِغْثًا فَٱضْرِب بِّهِۦ وَلَا تَحْنَثْۗ إِنَّا وَجَدْنَـٰهُ صَابِرًاۚ","s":0.866},{"l":3,"t":"نِّعْمَ ٱلْعَبْدُۖ إِنَّهُۥٓ أَوَّابٌ ﴿٤٤﴾","s":0.832}]],[37,46,456,[{"l":3,"t":" وَٱذْكُرْ عِبَـٰدَنَآ إِبْرَٰهِيمَ وَإِسْحَـٰقَ وَيَعْقُوبَ","s":0.832},{"l":4,"t":"أُو۟لِى ٱلْأَيْدِى وَٱلْأَبْصَـٰرِ ﴿٤٥﴾","s":0.951}]],[37,47,456,[{"l":4,